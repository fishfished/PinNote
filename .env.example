# Eazo Private Key to decrypt the user session token on the server
EAZO_PRIVATE_KEY=your_eazo_private_key_here

# Eazo app ID — used by @eazo/sdk on the browser to identify this app
# and exchange a GenAuth JWT for a session token.
NEXT_PUBLIC_EAZO_APP_ID=your_eazo_app_id_here

# PostgreSQL connection string (used by Drizzle ORM)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp

# Optional — override GenAuth defaults only if you are not on the Eazo platform tenant.
# NEXT_PUBLIC_GENAUTH_APP_ID=your_authing_app_id
# NEXT_PUBLIC_GENAUTH_APP_DOMAIN=https://your-tenant.genauth.ai
